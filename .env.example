# ============================================================
# Variables d'environnement LeasEval
# Copie ce fichier en .env et remplis les valeurs
# NE JAMAIS committer le .env dans GitHub !
# ============================================================

# --- Supabase ---
# Récupère ces valeurs dans : Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Stripe ---
# Récupère ces valeurs dans : Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_live_...          # ou sk_test_... en mode test
STRIPE_WEBHOOK_SECRET=whsec_...        # créé lors de la config du webhook

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://leaseval.vercel.app
